{
  "name": "stickernest-v5",
  "version": "0.0.1",
  "private": true,
  "description": "StickerNest V5 — Spatial Operating System",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "deps:validate": "dependency-cruiser src --config .dependency-cruiser.cjs",
    "deps:graph": "dependency-cruiser src --config .dependency-cruiser.cjs --output-type dot | dot -T svg > docs/dependency-graph.svg",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "plop": "plop --plopfile plop/plopfile.cjs",
    "scaffold:widget": "plop --plopfile plop/plopfile.cjs widget",
    "scaffold:module": "plop --plopfile plop/plopfile.cjs module",
    "scaffold:store": "plop --plopfile plop/plopfile.cjs store",
    "scaffold:event": "plop --plopfile plop/plopfile.cjs event",
    "scaffold:schema": "plop --plopfile plop/plopfile.cjs schema",
    "deploy:preview": "vercel",
    "deploy:prod": "vercel --prod",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:migrate": "supabase migration new",
    "db:lint": "supabase db lint",
    "db:diff": "supabase db diff",
    "prepare": "husky"
  },
  "dependencies": {
    "@lottiefiles/dotlottie-web": "^0.64.1",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@react-three/xr": "^6.6.29",
    "@supabase/supabase-js": "^2.97.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "ratk": "^0.3.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.0",
    "three": "^0.183.1",
    "vite": "^5.4.21",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.29",
    "zod": "^4.3.6",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@playwright/test": "^1.58.2",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/react": "^8.6.17",
    "@storybook/react-vite": "^8.6.17",
    "@storybook/test": "^8.6.17",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.0.0",
    "@types/three": "^0.183.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^2.0.0",
    "dependency-cruiser": "^17.3.8",
    "eslint": "^8.57.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-boundaries": "^4.2.0",
    "eslint-plugin-import": "^2.31.0",
    "happy-dom": "^20.6.3",
    "husky": "^9.0.0",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.2.7",
    "plop": "^4.0.5",
    "storybook": "^8.6.17",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0"
  }
}
