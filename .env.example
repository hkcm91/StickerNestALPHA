# =============================================================================
# StickerNest V5 — Environment Variables
# =============================================================================
#
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.

# Supabase — required for all functionality
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# =============================================================================
# Stripe — Payments & Subscriptions
# Get keys from https://dashboard.stripe.com/apikeys
# =============================================================================

# Main API key (secret or restricted)
STRIPE_SECRET_KEY=sk_test_or_rk_live_your_key

# Publishable key for client-side Stripe.js
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_or_pk_live_your_key

# Webhook secrets (get from Stripe Dashboard → Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_CONNECT_WEBHOOK_SECRET=whsec_your_connect_webhook_secret
STRIPE_CREATOR_WEBHOOK_SECRET=whsec_your_creator_webhook_secret

# Price IDs for subscription tiers (get from Stripe Dashboard → Products)
STRIPE_PRICE_CREATOR=price_creator_tier_id
STRIPE_PRICE_PRO=price_pro_tier_id
STRIPE_PRICE_ENTERPRISE=price_enterprise_tier_id

# =============================================================================
# Notion Integration
# Get credentials from https://www.notion.so/my-integrations
# =============================================================================

NOTION_OAUTH_CLIENT_ID=your_notion_client_id
NOTION_OAUTH_CLIENT_SECRET=your_notion_client_secret

# =============================================================================
# Security
# =============================================================================

# 32-byte hex key for encrypting user API keys
# Generate with: openssl rand -hex 32
API_KEY_SECRET=your_32_byte_hex_key

# =============================================================================
# URLs
# =============================================================================

# Your app's public URL (used for OAuth redirects, webhooks)
SITE_URL=http://localhost:5173
APP_URL=http://localhost:5173

# =============================================================================
# Optional
# =============================================================================

# Lottie animation search API
VITE_LOTTIE_SEARCH_API=
